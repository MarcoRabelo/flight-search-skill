# Auto-detect text files and normalize to LF
* text=auto eol=lf

# Python
*.py text eol=lf

# Shell scripts
*.sh text eol=lf

# Markdown
*.md text eol=lf

# JSON
*.json text eol=lf

# Prevent config.json from being committed (extra safety)
# Even if .gitignore fails, this provides a warning
config.json linguist-generated=true
